{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_authors}"
  ],
  "license": "${mod_license}",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.seniors.justlevelingfork.fabric.JustLevelingForkFabric"
    ],
    "client": [
      "com.seniors.justlevelingfork.JustLevelingClient"
    ]
  },
  "mixins": [
    "justlevelingfork.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": "${minecraft_version}",
    "fabric-api": "*",
    "trinkets": ">=3.10.0",
    "yet_another_config_lib_v3": ">=3.6.6",
    "cloth-config": "*"
  },
  "suggests": {
    "bettercombat": "*",
    "ftbquests": "*",
    "questlog": "*"
  }
}
